{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "rootDir": ".",
    "types": ["node", "@wdio/globals/types", "@wdio/mocha-framework"]
  },
  "include": ["**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
