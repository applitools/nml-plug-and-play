APPLITOOLS_API_KEY=YOUR_API_KEY_HERE

# Local Appium server (started separately, e.g. `appium`)
APPIUM_URL=http://127.0.0.1:4723

# Emulator / device
AVD_NAME=Pixel_8_API_35
PLATFORM_VERSION=15.0

# Local app path (bundled in static_instrumented_sample_application/android)
ANALYTICSX_APP_PATH=./static_instrumented_sample_application/android/AnalyticsX/AnalyticsX_XMLLayout.apk
ACCESSIBILITY_APP_PATH=./static_instrumented_sample_application/android/Accessibility/Accessibility_static_xmllayout.apk

# Set to "analyticsx" or "accessibility" — auto-selects the matching app path and spec file
ACTIVE_APP=accessibility

# AnalyticsX flow: compact | full  (default: full)
FLOW=full
