APPLITOOLS_API_KEY=
SAUCE_USERNAME=SAUCE_USERNAME_HERE
SAUCE_ACCESS_KEY=SAUCE_ACCESS_KEY_HERE
# us-west-1 (default) | eu-central-1 | etc.
SAUCE_REGION=us-west-1


# Upload each app to Sauce Labs app storage and paste the returned storage:filename=... or storage:<id> reference here.
SAUCE_APP_ANALYTICSX=storage:filename=AnalyticsX_XMLLayout.apk
ANALYTICSX_APP_PACKAGE=com.apexlytics.analyticsxandroid
ANALYTICSX_APP_ACTIVITY=com.apexlytics.analyticsxandroid.LoginActivity



SAUCE_APP_ACCESSIBILITY=storage:filename=AccessibilityTest_with_Material_UI.apk
ACCESSIBILITY_APP_PACKAGE=com.applitools.accessibilitytest
ACCESSIBILITY_APP_ACTIVITY=com.applitools.accessibilitytest.MainActivity

# Set to "analyticsx" or "accessibility" — auto-selects the matching app url,
# package, activity, and spec file
ACTIVE_APP=accessibility


DEVICE_NAME=Samsung Galaxy S22
PLATFORM_VERSION=16

# AnalyticsX flow: compact | full  (default: full)
FLOW=full
