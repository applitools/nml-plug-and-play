APPLITOOLS_API_KEY=YOUR_API_KEY_HERE

# Local Appium server (started separately, e.g. `appium`)
APPIUM_URL=http://127.0.0.1:4723

# Simulator / real device
DEVICE_NAME=iPhone 14
PLATFORM_VERSION=17

# Local app path (bundled in static_instrumented_sample_application/ios)
# NOTE: these are real-device .ipa builds — only used when IOS_TARGET=real (see below).
ANALYTICSX_APP_PATH=./static_instrumented_sample_application/ios/AnalyticsX/AnalyticsXUIKit.ipa
ACCESSIBILITY_APP_PATH=./static_instrumented_sample_application/ios/Accessibility/AccessibilityTestUIKit.ipa

# Set to "analyticsx" or "accessibility" — auto-selects the matching app path and spec file
ACTIVE_APP=accessibility

# AnalyticsX flow: compact | full  (default: full)
FLOW=full

# Toggle: "simulator" (default) targets DEVICE_NAME/PLATFORM_VERSION as a named Simulator.
# "real" runs against a physically connected iPhone (Appium auto-detects the UDID;
# set IOS_UDID to target a specific device). Real-device runs need a real-device-signed
# .ipa (like the bundled sample apps); Simulator runs need a Simulator-built .app instead.
IOS_TARGET=simulator
IOS_UDID=

# Simulator-side app builds (used when IOS_TARGET=simulator)
ANALYTICSX_APP_PATH_SIMULATOR=./static_instrumented_sample_application/ios/AnalyticsX/AnalyticsXUIKit-Simulator.app
ACCESSIBILITY_APP_PATH_SIMULATOR=./static_instrumented_sample_application/ios/Accessibility/AccessibilityTestUIKit.app
