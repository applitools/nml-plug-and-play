APPLITOOLS_API_KEY=YOUR_API_KEY_HERE
SAUCE_USERNAME=SAUCE_USERNAME_HERE
SAUCE_ACCESS_KEY=SAUCE_ACCESS_KEY_HERE
# us-west-1 (default) | eu-central-1 | etc.
SAUCE_REGION=us-west-1



# Upload each .ipa to Sauce Labs app storage and paste the returned storage:filename=... reference here.
SAUCE_APP_ANALYTICSX=storage:filename=AnalyticsXUIKit.ipa
SAUCE_APP_ACCESSIBILITY=storage:filename=AccessibilityTestUIKit.ipa

# Set to "analyticsx" or "accessibility" — auto-selects the matching app url and spec file
ACTIVE_APP=accessibility

DEVICE_NAME=iPhone 15
PLATFORM_VERSION=18.7.2

# AnalyticsX flow: compact | full  (default: full)
FLOW=full
