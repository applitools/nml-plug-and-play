APPLITOOLS_API_KEY=YOUR_API_KEY_HERE

# --- iOS device on BrowserStack (wdio.ios.browserstack.conf.ts) ---
BROWSERSTACK_USERNAME=YOUR_BROWSERSTACK_USERNAME_HERE
BROWSERSTACK_ACCESS_KEY=YOUR_BROWSERSTACK_ACCESS_KEY_HERE

# BrowserStack requires pre-uploading the .ipa via their REST API (you cannot use a local file path).
# Upload it, then paste the returned bs://<app_id> value here.
BROWSERSTACK_APP_ANALYTICSX=bs://PASTE_ANALYTICSX_APP_ID_HERE
BROWSERSTACK_APP_ACCESSIBILITY=bs://PASTE_ACCESSIBILITY_APP_ID_HERE

# Set to "analyticsx" or "accessibility" — auto-selects the matching app url and spec file
ACTIVE_APP=accessibility

DEVICE_NAME=iPhone 14
PLATFORM_VERSION=17

# AnalyticsX flow: compact | full  (default: full)
FLOW=full
