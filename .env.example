APPLITOOLS_API_KEY=YOUR_APPLITOOLS_API_KEY_HERE

# --- Android device on Perfecto (wdio.android.perfecto.conf.js) ---
# Your Perfecto cloud subdomain, e.g. "demo" for demo.perfectomobile.com
PERFECTO_CLOUD_NAME=PERFECTO_CLOUD_NAME_HERE
PERFECTO_SECURITY_TOKEN=PERFECTO_SECURITY_TOKEN_HERE

# Upload each app to the Perfecto media repository and paste the returned repository path here,
# e.g. PERFECTO:REPOSITORY:PUBLIC:AnalyticsX.apk
PERFECTO_APP_ANALYTICSX=PERFECTO:REPOSITORY:PASTE_ANALYTICSX_APK_HERE
ANALYTICSX_APP_PACKAGE=com.apexlytics.analyticsxandroid
ANALYTICSX_APP_ACTIVITY=com.apexlytics.analyticsxandroid.LoginActivity

PERFECTO_APP_ACCESSIBILITY=PERFECTO:REPOSITORY:PASTE_ACCESSIBILITY_APK_HERE
ACCESSIBILITY_APP_PACKAGE=com.applitools.accessibilitytest
ACCESSIBILITY_APP_ACTIVITY=com.applitools.accessibilitytest.MainActivity

# Set to "analyticsx" or "accessibility" — auto-selects the matching app url and spec file
ACTIVE_APP=accessibility
DEVICE_NAME=Samsung Galaxy S23
PLATFORM_VERSION=13

# AnalyticsX flow: compact | full  (default: full)
FLOW=full
